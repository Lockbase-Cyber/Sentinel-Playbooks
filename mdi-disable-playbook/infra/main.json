  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "logicApp",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "logicAppName": {
            "value": "[parameters('logicAppName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "actionsToEnable": {
            "value": "[parameters('actionsToEnable')]"
          },
