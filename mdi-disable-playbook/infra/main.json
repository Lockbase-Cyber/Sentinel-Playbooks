                      "id": "",
                      "connectionProperties": {
                        "authentication": {
                          "type": "ManagedServiceIdentity"
                        }
                      }
                    }
                  }
                }
              }
            },
            "sentinelManagedApiId": "[subscriptionResourceId('Microsoft.Web/locations/managedApis', parameters('location'), 'azuresentinel')]"
          },
